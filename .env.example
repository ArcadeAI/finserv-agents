# ── Live Mode (read by the local Next.js app) ───────────────────────────
ANTHROPIC_API_KEY=
ARCADE_API_KEY=
ARCADE_GATEWAY_URL=
# Stable developer-chosen identifier for the Arcade user context.
# Your email is a good default for local testing.
ARCADE_USER_ID=

# ── Database (local) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/loanops

# ── Redis Cloud (single live Redis data plane) ──────────────────────────
# Use one shared Redis Cloud URL for:
# - the local Next.js app
# - RedisVL-managed entity indices and JSON data
# - the deployed Arcade toolkit
REDIS_URL=rediss://default:password@redis.example.com:6380/0

# ── Optional: offline embeddings generation only ────────────────────────
# Only needed if you run database/generate_embeddings.py.
OPENAI_API_KEY=
